# --- Generated by perf runs (framework CLI, examples, custom runners) ---
# JTL, JMX, index.html, report.json, allure-results/, …
perf-output/

# JMeter logs (runs sometimes leave these in cwd as well as under perf-output)
jmeter.log
*.log

# Stray JMeter/XML artifacts under this package root (artifacts belong in perf-output/<runId>/)
/*.jmx
/*.jtl

# Optional: local JMeter tarball extract or tool cache kept next to the package
.tools/

# Browser bundle — generated by `npm run build:report-client` or `prepare`
src/reporting/html-report/report.js

# npm / frontend subproject
node_modules/
dashboard/node_modules/
dashboard/dist/

# TypeScript compilation output (`npm run build` → tsconfig.json outDir)
dist/

# Incremental compilation / ESLint caches
*.tsbuildinfo
.eslintcache

# Coverage if you wire nyc/jest/vitest here later
coverage/

# Secrets and local overrides (mirror repo root conventions)
.env
.env.*
!.env.example

# macOS junk (harmless duplicate if workspace root ignores it already)
.DS_Store
